{
  "Beloveful React Component": {
    "prefix": "bcomp",
    "body": [
      "import { useState, useEffect } from 'react';",
      "import { useQuery } from '@tanstack/react-query';",
      "",
      "interface ${1:ComponentName}Props {",
      "  // Define props here",
      "}",
      "",
      "const ${1:ComponentName}: React.FC<${1:ComponentName}Props> = ({}) => {",
      "  const [state, setState] = useState<string>('');",
      "",
      "  const { data, isLoading, error } = useQuery({",
      "    queryKey: ['${2:resource}'],",
      "    queryFn: async () => {",
      "      // Add API call here",
      "      const response = await fetch('/api/${2:resource}');",
      "      return response.json();",
      "    },",
      "  });",
      "",
      "  useEffect(() => {",
      "    // Add side effects here",
      "  }, []);",
      "",
      "  if (isLoading) return <div>Loading...</div>;",
      "  if (error) return <div>Error loading data</div>;",
      "",
      "  return (",
      "    <div className=\"${3:container-class}\">",
      "      {/* Component content */}",
      "    </div>",
      "  );",
      "};",
      "",
      "export default ${1:ComponentName};"
    ],
    "description": "Create a new React component with query hook for Beloveful project"
  },
  "Beloveful API Hook": {
    "prefix": "bhook",
    "body": [
      "import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query';",
      "import axios from 'axios';",
      "",
      "interface ${1:Resource}Data {",
      "  id: string;",
      "  // Add other fields",
      "}",
      "",
      "export const use${1:Resource}s = () => {",
      "  return useQuery<{ data: ${1:Resource}Data[] }>({",
      "    queryKey: ['${2:resources}'],",
      "    queryFn: async () => {",
      "      const response = await axios.get('/api/${2:resources}');",
      "      return response.data;",
      "    },",
      "    staleTime: 5 * 60 * 1000, // 5 minutes",
      "  });",
      "};",
      "",
      "export const use${1:Resource} = (id: string) => {",
      "  return useQuery<{ data: ${1:Resource}Data }>({",
      "    queryKey: ['${2:resources}', id],",
      "    queryFn: async () => {",
      "      const response = await axios.get(`/api/${2:resources}/${id}`);",
      "      return response.data;",
      "    },",
      "    enabled: !!id,",
      "  });",
      "};"
    ],
    "description": "Create API hooks with TanStack Query for Beloveful project"
  },
  "Beloveful Page Component": {
    "prefix": "bpage",
    "body": [
      "import { Helmet } from 'react-helmet-async';",
      "import PageContainer from '@/components/PageContainer';",
      "import { use${1:Resource}s } from '@/hooks/use${1:Resource}s';",
      "",
      "const ${2:PageName}Page = () => {",
      "  const { data, isLoading, error } = use${1:Resource}s();",
      "",
      "  return (",
      "    <>",
      "      <Helmet>",
      "        <title>${3:Page Title} | Beloveful</title>",
      "        <meta name=\"description\" content=\"${4:Page description}\" />",
      "      </Helmet>",
      "",
      "      <PageContainer>",
      "        <div className=\"py-8\">",
      "          <header className=\"mb-8 text-center\">",
      "            <h1 className=\"text-4xl font-bold text-gray-900 dark:text-white\">${3:Page Title}</h1>",
      "            <p className=\"mt-4 text-xl text-gray-600 dark:text-gray-300\">${4:Page description}</p>",
      "          </header>",
      "",
      "          <main>",
      "            {isLoading ? (",
      "              <div className=\"text-center py-8\">Loading...</div>",
      "            ) : error ? (",
      "              <div className=\"text-center py-8 text-red-500\">Error loading content</div>",
      "            ) : (",
      "              <div>",
      "                {/* Render content here */}",
      "              </div>",
      "            )}",
      "          </main>",
      "        </div>",
      "      </PageContainer>",
      "    </>",
      "  );",
      "};",
      "",
      "export default ${2:PageName}Page;"
    ],
    "description": "Create a new page component for Beloveful project"
  }
}