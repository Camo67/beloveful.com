# Local Environment Configuration for beloveful.com
# Copy this file to .env.local and fill in your credentials
# IMPORTANT: Do NOT commit .env.local to version control!

# ============================================
# Bluehost/cPanel FTP Configuration
# ============================================
# These credentials are used for:
# - Scanning Bluehost FTP server for existing images
# - Syncing image paths from cPanel hosting
# - Admin panel "Scan Bluehost FTP" functionality

# Bluehost FTP Server (IP or domain)
# Find this in your Bluehost cPanel under "FTP Accounts"
CPANEL_FTP_HOST=67.222.38.79

# FTP Port (usually 21 for standard FTP, 22 for SFTP)
CPANEL_FTP_PORT=21

# FTP Username (from Bluehost cPanel > FTP Accounts)
CPANEL_FTP_USER=belovefu

# FTP Password (from Bluehost cPanel when you created the FTP account)
# If you don't know it, reset it in cPanel > FTP Accounts
CPANEL_FTP_PASSWORD=YOUR_FTP_PASSWORD_HERE

# Root directory on the FTP server where images are stored
# This should be the absolute path from the FTP root
CPANEL_FTP_ROOT=/public_html/beloveful.com/public_html/images

# Use secure FTP (FTPS)? Set to 'true' if your host requires it
# Bluehost typically uses standard FTP (not FTPS)
CPANEL_FTP_SECURE=false

# Base URL for accessing images publicly
# This is prepended to image paths when generating URLs
CPANEL_IMAGES_BASE_URL=/Website%20beloveful.com

# ============================================
# Alternative: SFTP Configuration (More Secure)
# ============================================
# If you prefer SFTP over FTP, use these settings instead:

# SFTP Server (can be same as FTP host)
# CPANEL_SFTP_HOST=67.222.38.79

# SFTP Port (usually 22)
# CPANEL_SFTP_PORT=22

# SFTP Username
# CPANEL_SFTP_USER=belovefu

# Path to your SSH private key file (for key-based auth)
# CPANEL_SFTP_PRIVATE_KEY_PATH=~/.ssh/id_rsa

# Passphrase for your SSH key (if applicable)
# CPANEL_SFTP_PASSPHRASE=your-passphrase

# OR use password authentication:
# CPANEL_SFTP_PASSWORD=your-sftp-password

# SFTP root directory
# CPANEL_SFTP_ROOT=/public_html/beloveful.com/public_html/images

# ============================================
# Other Settings
# ============================================

# Development mode
VITE_DEV_MODE=true
VITE_DEBUG_UPLOADS=false

# Zoho Calendar Integration (optional)
ZOHO_PUBLIC_EVENTS_FEED_URL=

# Contact Form Configuration
CONTACT_FORM_TO_EMAIL=tony@beloveful.com
CONTACT_FORM_FROM_EMAIL=website@beloveful.com
CONTACT_FORM_FROM_NAME=Beloveful Contact Form

# MailChannels API (for email delivery)
# MAILCHANNELS_API_URL=https://api.mailchannels.net/tx/v1/send
