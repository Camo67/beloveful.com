Options -Indexes
DirectoryIndex index.html

RewriteEngine On

RewriteRule ^_cms_data/ - [F,L]

RewriteCond %{REQUEST_URI} ^/api(?:/.*)?$
RewriteRule ^api(?:/(.*))?$ api/index.php [QSA,L]

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^ index.html [L]

