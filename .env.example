# Example environment for beloveful.com
# Copy this file to .env.local and fill in values. Do not commit real secrets.

# Cloudinary credentials for import script (server-side)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Client-side Cloudinary config
# Used by @cloudinary/react via src/lib/cloudinary.ts
VITE_CLOUDINARY_CLOUD_NAME=

# Spotify Web SDK Configuration
# Get these values from https://developer.spotify.com/dashboard
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Optional: Custom redirect URI (defaults to current origin)
# VITE_SPOTIFY_REDIRECT_URI=http://localhost:8080

# Backblaze B2 Configuration
# Get these from your Backblaze B2 account > App Keys
VITE_B2_APPLICATION_KEY=your_application_key_here
VITE_B2_BUCKET_ID=your_bucket_id_here

# Replace 'beloveful-images' with your actual bucket name in b2-config.ts
# Replace 'https://f005.backblazeb2.com' with your bucket's download URL in b2-config.ts

# Additional B2 configuration (optional)
VITE_B2_REGION=us-west-002
VITE_IMAGE_CDN_URL=https://your-cdn-domain.com

# Development settings
VITE_DEV_MODE=true
VITE_DEBUG_UPLOADS=false

# Privacy and legal template configuration
VITE_PRIVACY_CONSENT_VERSION=2026-03-23
VITE_PRIVACY_POLICY_VERSION=2026-03-23
VITE_PRIVACY_LAST_UPDATED=2026-03-23
VITE_PRIVACY_DISABLE_OPTIONAL_TRACKING=false
VITE_PRIVACY_SETTINGS_ENABLED=true

VITE_COMPANY_NAME={{COMPANY_NAME}}
VITE_LEGAL_ENTITY={{LEGAL_ENTITY}}
VITE_CONTACT_EMAIL={{CONTACT_EMAIL}}
VITE_DPO_EMAIL={{DPO_EMAIL}}
VITE_JURISDICTIONS={{JURISDICTIONS}}
VITE_TRACKING_TOOLS={{TRACKING_TOOLS}}
VITE_RETENTION_SCHEDULE={{RETENTION_SCHEDULE}}
VITE_THIRD_PARTIES={{THIRD_PARTIES}}
VITE_LAWFUL_BASES={{LAWFUL_BASES}}

# Privacy integrations (all disabled by default)
VITE_GA_ENABLED=false
VITE_GA_MEASUREMENT_ID=
VITE_PLAUSIBLE_ENABLED=false
VITE_PLAUSIBLE_DOMAIN=
VITE_POSTHOG_ENABLED=false
VITE_POSTHOG_API_KEY=
VITE_POSTHOG_HOST=
VITE_META_ADS_ENABLED=false
VITE_META_PIXEL_ID=
VITE_GOOGLE_ADS_ENABLED=false
VITE_GOOGLE_ADS_CONVERSION_ID=

# cPanel image sync configuration
CPANEL_FTP_HOST=ftp.example.com
CPANEL_FTP_PORT=21
CPANEL_FTP_USER=ftp_user
CPANEL_FTP_PASSWORD=change_me
CPANEL_FTP_ROOT=/public_html/images
CPANEL_IMAGES_BASE_URL=https://beloveful.com/images
CPANEL_FTP_SECURE=false
