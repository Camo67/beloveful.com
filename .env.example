# Example environment for beloveful.com
# Copy this file to .env.local and fill in values. Do not commit real secrets.

# Cloudinary credentials for import script (server-side)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Client-side Cloudinary config
# Used by @cloudinary/react via src/lib/cloudinary.ts
VITE_CLOUDINARY_CLOUD_NAME=

# Spotify Web SDK Configuration
# Get these values from https://developer.spotify.com/dashboard
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Optional: Custom redirect URI (defaults to current origin)
# VITE_SPOTIFY_REDIRECT_URI=http://localhost:8080

# Backblaze B2 Configuration
# Get these from your Backblaze B2 account > App Keys
VITE_B2_APPLICATION_KEY=your_application_key_here
VITE_B2_BUCKET_ID=your_bucket_id_here

# Replace 'beloveful-images' with your actual bucket name in b2-config.ts
# Replace 'https://f005.backblazeb2.com' with your bucket's download URL in b2-config.ts

# Additional B2 configuration (optional)
VITE_B2_REGION=us-west-002
VITE_IMAGE_CDN_URL=https://your-cdn-domain.com

# Development settings
VITE_DEV_MODE=true
VITE_DEBUG_UPLOADS=false

# cPanel image sync configuration
CPANEL_FTP_HOST=ftp.theoriawellness.org
CPANEL_FTP_PORT=21
CPANEL_FTP_USER=
CPANEL_FTP_PASSWORD=
CPANEL_FTP_ROOT=/public_html/images
CPANEL_IMAGES_BASE_URL=https://beloveful.com/images
CPANEL_FTP_SECURE=false

# Public Zoho events feed used by functions/api/events/upcoming.ts
# Set this to the public JSON or ICS feed URL for the Beloveful Zoho calendar.
ZOHO_PUBLIC_EVENTS_FEED_URL=

# Optional: override the public Zoho calendar ID used by the automatic server-side month-view scraper.
# ZOHO_PUBLIC_CALENDAR_ID=

# Optional: override the public Zoho calendar ID used by the default /events embed.
# The built-in fallback uses the last known public Beloveful calendar and renders it in month view
# with the title events@beloveful.com.
# VITE_EVENTS_CALENDAR_ID=

# Optional: override the full public Zoho calendar embed shown on /events.
# VITE_EVENTS_CALENDAR_EMBED=

# Contact form delivery
# The site runs on a Cloudflare Worker, so backend contact form submissions are sent
# through the Worker endpoint at /api/contact.
CONTACT_FORM_TO_EMAIL=tony@beloveful.com
CONTACT_FORM_FROM_EMAIL=website@beloveful.com
CONTACT_FORM_FROM_NAME=Beloveful Contact Form

# Optional: set CONTACT_FORM_DELIVERY_MODE=log for local testing without sending live email.
# CONTACT_FORM_DELIVERY_MODE=mailchannels

# Optional: override the MailChannels delivery endpoint if you use a custom mail proxy.
# MAILCHANNELS_API_URL=https://api.mailchannels.net/tx/v1/send
